<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] bg-slate-50 py-10 px-4 md:px-12 box-border flex flex-col items-center">
    <div class="w-full max-w-4xl space-y-6 text-left">
        <div>
            <a href="/home" class="text-[10px] text-indigo-600 font-bold uppercase tracking-wider no-underline hover:underline mb-2 inline-block"><i class="fa-solid fa-arrow-left mr-1"></i> Back</a>
            <h1 class="text-4xl font-sans font-extrabold m-0 tracking-tight text-[#3b4276]">
                Archived Notifications
            </h1>
            <p class="text-slate-500 text-sm mt-1 m-0">
                A historical log of announcements you previously cleared from your main feed.
            </p>
        </div>

        <div class="space-y-3">
            <% if (archivedAnnouncements && archivedAnnouncements.length > 0) { %>
                <% archivedAnnouncements.forEach(function(item) { %>
                    <div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm flex gap-4 items-start opacity-70 hover:opacity-100 transition-opacity">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-slate-100 text-slate-500 border border-slate-200 shadow-sm">
                            <i class="fa-solid fa-box-archive"></i>
                        </div>
                        <div>
                            <div class="flex items-center gap-2 flex-wrap mb-1">
                                <h4 class="text-sm font-bold text-slate-800 m-0"><%= item.title %></h4>
                                <span class="text-[10px] text-slate-400 font-mono"><%= new Date(item.createdAt).toLocaleDateString() %></span>
                            </div>
                            <p class="text-xs text-slate-500 m-0 leading-relaxed"><%= item.body %></p>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="bg-white rounded-3xl border border-slate-200 p-12 text-center shadow-sm">
                    <p class="text-slate-400 text-sm italic m-0">Your archive is empty.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>