<!--Global Header Interface Navigation Bar-->
<nav class="w-full bg-[#3b4276] px-6 md:px-12 py-4 shadow-md sticky top-0 z-50 select-none box-border flex items-center justify-between">
    <div class="w-full flex justify-between items-center h-[44px]">
        
        <!--Brand Branding Identity Logo Segment-->
        <div class="flex items-center space-x-8">
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,700&display=swap');
                .ams-topbar-logo {
                    font-family: 'Playfair Display', Georgia, serif !important;
                }
            </style>
            <a href="/home" class="ams-topbar-logo text-white text-3xl italic font-bold tracking-wider no-underline transition-transform duration-200 hover:scale-105">
                AMS
            </a>

            <!--Central Links Menu (My Room is hidden unless they have an active application)-->
            <div class="hidden md:flex items-center space-x-6">
                <a href="/home" class="text-sm font-medium transition-all duration-200 text-white/90 hover:text-white no-underline">
                    Home
                </a>
                
                <!--Only show My Room Hub to active/pending tenants-->
                <% if (user && typeof hasRentedRoom !== 'undefined' && hasRentedRoom) { %>
                    <a href="/my-room" class="text-sm font-medium transition-all duration-200 text-white/90 hover:text-white no-underline">
                        My Room Hub
                    </a>
                <% } %>
            </div>
        </div>

        <!--Right Side Action Section-->
        <div class="flex items-center space-x-4">
            <% if (user) { %>
                <!--Dynamic Notification Bell Component-->
                <div class="relative inline-block text-left" id="notification-area">
                    <button 
                        type="button"
                        onclick="toggleNotificationDropdown(event)"
                        class="relative w-9 h-9 rounded-full bg-white/5 hover:bg-white/10 text-white flex items-center justify-center border-0 cursor-pointer transition-colors outline-none"
                    >
                        <i class="fa-solid fa-bell"></i>
                        <% if (announcements && announcements.length > 0) { %>
                            <span class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-red-500 text-white text-[9px] font-black rounded-full flex items-center justify-center animate-pulse">
                                <%= announcements.length %>
                            </span>
                        <% } %>
                    </button>

                    <!--Notification Dropdown Panel-->
                    <div id="notification-dropdown" class="hidden absolute right-0 mt-3 w-80 bg-white rounded-2xl shadow-2xl border border-slate-100 py-3 z-50 text-left flex flex-col max-h-[420px]">
                        <div class="px-4 pb-2 border-b border-slate-100 flex items-center justify-between">
                            <span class="font-bold text-slate-800 text-sm">Notifications</span>
                        </div>
                        
                        <div class="flex-grow overflow-y-auto divide-y divide-slate-50">
                            <% if (announcements && announcements.length > 0) { %>
                                <% announcements.forEach(function(notif) { %>
                                    <div class="p-3.5 flex items-start space-x-3 transition-colors hover:bg-slate-50">
                                        <div class="w-8 h-8 rounded-lg bg-indigo-50 border border-indigo-100 text-indigo-500 flex items-center justify-center shrink-0">
                                            <i class="fa-solid fa-bullhorn text-xs"></i>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <p class="text-xs m-0 leading-snug font-bold text-slate-800"><%= notif.title %></p>
                                            <p class="text-[11px] text-slate-500 m-0 mt-0.5 leading-normal"><%= notif.body %></p>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="py-12 text-center text-slate-400 text-xs italic">
                                    No new notifications
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!--Polished Custom Dropdown matching JSX Design-->
                <div class="relative inline-block text-left" id="profile-dropdown-area">
                    <button
                        type="button"
                        onclick="toggleProfileDropdown(event)"
                        class="flex items-center space-x-3 text-white/90 hover:text-white bg-white/5 hover:bg-white/10 px-3 py-1.5 rounded-xl border-0 bg-transparent cursor-pointer transition-all duration-200 select-none outline-none"
                    >
                        <span class="font-bold text-sm tracking-wide"><%= user.first_name %></span>
                        
                        <div class="w-9 h-9 rounded-full bg-indigo-600 border border-white/20 text-white flex items-center justify-center text-xs font-black tracking-wider shadow-inner">
                            <%= user.first_name[0] %><%= user.last_name[0] %>
                        </div>
                        
                        <i class="fa-solid fa-chevron-down text-[10px] opacity-70 transition-transform duration-200" id="profile-chevron"></i>
                    </button>

                    <!--Account Submenu Selection List Panel-->
                    <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-52 bg-white rounded-2xl shadow-2xl border border-slate-100 py-1.5 z-50 overflow-hidden text-left">
                        <!--Display User Details-->
                        <div class="p-3 border-b border-slate-100 bg-slate-50 select-none">
                            <span class="text-xs font-bold text-slate-700 block truncate"><%= user.first_name %> <%= user.last_name %></span>
                            <span class="text-[10px] text-slate-400 block truncate font-medium mt-0.5"><%= user.email_address %></span>
                        </div>
                        
                        <!--Menu Options-->
                        <a
                            href="/profile-settings"
                            class="w-full px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 flex items-center space-x-2.5 transition-colors border-0 bg-transparent text-left cursor-pointer font-semibold no-underline box-border"
                        >
                            <i class="fa-solid fa-cog text-slate-400 text-xs"></i>
                            <span>Profile Settings</span>
                        </a>
                        
                        <div class="border-t border-slate-100 my-1"></div>
                        
                        <a
                            href="/logout"
                            class="w-full px-4 py-3 text-sm text-rose-600 hover:bg-rose-50 flex items-center space-x-2.5 transition-colors border-0 bg-transparent text-left cursor-pointer font-bold no-underline box-border"
                        >
                            <i class="fa-solid fa-sign-out-alt text-xs"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </div>
            <% } else { %>
                <!--Sign In Action Link-->
                <a href="/login" class="bg-white/10 hover:bg-white/20 text-white font-bold px-5 py-2.5 rounded-xl text-xs border-0 cursor-pointer no-underline transition-all duration-150">
                    Sign In
                </a>
            <% } %>
        </div>
    </div>
</nav>

<!--Native JavaScript Event Listeners to Handle Clicks and Outside Clicks Flawlessly-->
<script>
    function toggleProfileDropdown(e) {
        e.stopPropagation();
        const dropdown = document.getElementById('profile-dropdown');
        const chevron = document.getElementById('profile-chevron');
        const isHidden = dropdown.classList.contains('hidden');
        
        // Close other dropdowns
        document.getElementById('notification-dropdown').classList.add('hidden');
        
        if (isHidden) {
            dropdown.classList.remove('hidden');
            chevron.classList.add('rotate-180');
        } else {
            dropdown.classList.add('hidden');
            chevron.classList.remove('rotate-180');
        }
    }

    function toggleNotificationDropdown(e) {
        e.stopPropagation();
        const dropdown = document.getElementById('notification-dropdown');
        const isHidden = dropdown.classList.contains('hidden');
        
        // Close other dropdowns
        document.getElementById('profile-dropdown').classList.add('hidden');
        document.getElementById('profile-chevron').classList.remove('rotate-180');
        
        if (isHidden) {
            dropdown.classList.remove('hidden');
        } else {
            dropdown.classList.add('hidden');
        }
    }

    // Handle outside clicks to close active menus immediately
    document.addEventListener('click', function(event) {
        const profileArea = document.getElementById('profile-dropdown-area');
        const notificationArea = document.getElementById('notification-area');
        
        if (profileArea && !profileArea.contains(event.target)) {
            document.getElementById('profile-dropdown').classList.add('hidden');
            const chevron = document.getElementById('profile-chevron');
            if (chevron) chevron.classList.remove('rotate-180');
        }
        
        if (notificationArea && !notificationArea.contains(event.target)) {
            document.getElementById('notification-dropdown').classList.add('hidden');
        }
    });
</script>