<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] bg-slate-50 py-10 px-4 md:px-12 box-border flex flex-col items-center">
    <div class="w-full max-w-4xl space-y-8 flex flex-col justify-start text-left">

        <div class="border-b border-slate-200 pb-4">
            <h1 class="text-4xl font-sans font-extrabold m-0 tracking-tight select-none" style="color: '#3b4276';">
                Rent Application Form
            </h1>
            <p class="text-slate-500 text-sm mt-1 m-0">
                Complete the required documentation onboarding framework below to process your lease application.
            </p>
        </div>

        <form class="bg-white rounded-3xl border border-slate-100 shadow-md p-6 md:p-10 space-y-8" action="/rent-application" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="roomName" value="Room <%= roomSelection %>" />
            
            <div class="space-y-4">
                <h3 class="text-lg font-bold m-0 border-b border-slate-100 pb-2" style="color: '#3b4276';">Application Parameters</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="flex flex-col space-y-1.5">
                        <label class="text-sm font-bold text-slate-700">No. Occupants (Max 4)</label>
                        <input type="number" name="occupants" min="1" max="4" required class="w-full px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-800 text-sm shadow-inner" />
                    </div>
                    <div class="flex flex-col space-y-1.5">
                        <label class="text-sm font-bold text-slate-700">Months of Rent (Min 3)</label>
                        <input type="number" name="monthsOfRent" min="3" required class="w-full px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-800 text-sm shadow-inner" />
                    </div>
                </div>
            </div>

            <!--Document Upload Vectors-->
            <div class="space-y-4">
                <h3 class="text-lg font-bold m-0 border-b border-slate-100 pb-2" style="color: '#3b4276';">Verification Documents</h3>
                <div class="grid grid-cols-1 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Valid ID Card (Front Side) *</label>
                        <input type="file" name="validIdFrontFile" required class="text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Valid ID Card (Back Side) *</label>
                        <input type="file" name="validIdBackFile" required class="text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">NBI Clearance Form Document *</label>
                        <input type="file" name="nbiFile" required class="text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
                    </div>
                </div>
            </div>

            <div class="pt-4 border-t border-slate-100">
                <button type="submit" class="w-full sm:w-auto bg-[#6366f1] hover:bg-[#4f46e5] text-white font-bold px-12 py-3.5 rounded-xl text-base transition-all shadow-md border-0 cursor-pointer">
                    Submit Application
                </button>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer') %>