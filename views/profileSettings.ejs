<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] bg-slate-50 py-10 px-4 md:px-12 box-border flex flex-col items-center">
    <div class="w-full max-w-4xl space-y-8 flex flex-col justify-start text-left">
        <div>
            <h1 class="text-4xl font-sans font-extrabold m-0 tracking-tight select-none text-[#3b4276]">
                Profile Settings
            </h1>
            <p class="text-slate-500 text-sm mt-1 m-0">
                Review and maintain your master identity records configurations below.
            </p>
        </div>

        <div class="bg-white rounded-3xl border border-slate-100 shadow-md p-6 md:p-10 space-y-8">
            <form class="space-y-6" action="/profile-settings" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="flex flex-col space-y-1.5">
                        <label class="text-sm font-bold text-slate-700">First Name</label>
                        <input type="text" name="firstName" value="<%= user.first_name %>" required class="w-full px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-800 text-sm" />
                    </div>
                    <div class="flex flex-col space-y-1.5">
                        <label class="text-sm font-bold text-slate-700">Last Name</label>
                        <input type="text" name="lastName" value="<%= user.last_name %>" required class="w-full px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-800 text-sm" />
                    </div>
                </div>
                <button type="submit" class="bg-[#6366f1] hover:bg-[#4f46e5] text-white font-bold px-6 py-2.5 rounded-xl text-xs border-0 cursor-pointer shadow-sm transition-colors">
                    Save Changes
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>