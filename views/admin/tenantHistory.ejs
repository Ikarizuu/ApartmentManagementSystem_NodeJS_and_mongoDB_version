<%- include('../partials/header') %>
<div class="flex h-screen bg-slate-50 overflow-hidden">
    <%- include('../partials/adminSidebar') %>
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0 relative z-50">
            <h2 class="text-2xl font-bold text-[#1e293b] m-0 tracking-tight">Tenant Billing Records</h2>
        </header>

        <main class="flex-1 overflow-y-auto p-8">
            <div class="max-w-6xl mx-auto space-y-6">
                <!-- Back Action & Header Info -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white p-5 border border-slate-200 rounded-xl shadow-sm">
                    <div>
                        <h3 class="text-lg font-black text-slate-800 m-0"><%= tenantUser.firstName %> <%= tenantUser.lastName %></h3>
                        <p class="text-xs text-slate-500 m-0 mt-0.5"><%= tenantUser.emailAddress %></p>
                    </div>
                    <button onclick="window.history.back()" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-4 py-2 rounded-lg text-xs shadow-sm cursor-pointer border border-slate-300 transition-colors">
                        <i class="fa-solid fa-arrow-left mr-1.5"></i> Return to Directory
                    </button>
                </div>

                <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                    <% if (payments && payments.length > 0) { %>
                        <table class="w-full text-sm text-left border-collapse">
                            <thead class="bg-slate-100/75 border-b border-slate-200 text-[10px] font-bold text-slate-500 uppercase tracking-wider">
                                <tr>
                                    <th class="py-4 px-6">Payment Date</th>
                                    <th class="py-4 px-6">Assigned Space</th>
                                    <th class="py-4 px-6">Billing Category</th>
                                    <th class="py-4 px-6">Method Used</th>
                                    <th class="py-4 px-6 text-center">Status</th>
                                    <th class="py-4 px-6 text-right">Amount (₱)</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% payments.forEach(function(p) { %>
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="py-4 px-6 text-slate-500 text-xs font-mono"><%= p.date %></td>
                                        <td class="py-4 px-6 font-bold text-indigo-600">Room <%= p.roomName %></td>
                                        <td class="py-4 px-6 text-xs capitalize"><span class="px-2 py-0.5 rounded bg-slate-100 text-slate-600 font-medium"><%= p.billingType %></span></td>
                                        <td class="py-4 px-6 text-xs font-semibold text-slate-700"><%= p.method %></td>
                                        <td class="py-4 px-6 text-center">
                                            <span class="inline-flex items-center text-[10px] font-bold uppercase px-2.5 py-1 rounded-md <%= p.status === 'completed' ? 'text-emerald-700 bg-emerald-100' : 'text-amber-700 bg-amber-100' %>">
                                                <%= p.status %>
                                            </span>
                                        </td>
                                        <td class="py-4 px-6 text-right text-emerald-600 font-extrabold">₱<%= p.amountPaid.toLocaleString(undefined, { minimumFractionDigits: 2 }) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div class="p-12 text-center">
                            <div class="w-16 h-16 bg-slate-50 border border-slate-100 text-slate-400 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                                <i class="fa-solid fa-receipt"></i>
                            </div>
                            <h3 class="text-slate-700 font-bold m-0 text-base">No History Found</h3>
                            <p class="text-slate-400 text-xs m-0 mt-1">This user currently has no transaction records.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</div>
<%- include('../partials/footer') %>