<%- include('../partials/header') %>
<div class="flex h-screen bg-slate-50 overflow-hidden">
    <!--Admin Left Rail Layout Sidebar-->
    <%- include('../partials/adminSidebar') %>

    <!--Right Main Interface Window Panel Area Layout Container-->
    <div class="flex-1 flex flex-col overflow-hidden">
        <!--Dashboard Upper Status Bar Header Content Row Panel Element Context-->
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0 select-none relative z-50">
            <h2 class="text-2xl font-bold text-[#1e293b] opacity-100 m-0 tracking-tight">Admin Dashboard</h2>
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold shadow-md text-sm">Ad</div>
            </div>
        </header>

        <!--Main Metrics Operational Grid Track Layout Area Workspace-->
        <main class="flex-1 overflow-y-auto p-6 md:p-8">
            <div class="mx-auto max-w-7xl space-y-8">
                
                <!--Statistical Metrics Matrix Cards Group Row Track Layout Block Container-->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg bg-emerald-50 text-emerald-600 mb-3"><i class="fa-solid fa-dollar-sign"></i></div>
                        <div>
                            <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide m-0 mb-1">Total Revenue</p>
                            <p class="text-2xl font-bold text-slate-800 m-0 leading-none">₱<%= stats.totalRevenue.toLocaleString() %></p>
                        </div>
                    </div>
                    <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg bg-indigo-50 text-indigo-600 mb-3"><i class="fa-solid fa-users"></i></div>
                        <div>
                            <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide m-0 mb-1">Active Tenants</p>
                            <p class="text-2xl font-bold text-slate-800 m-0 leading-none"><%= stats.activeTenants %></p>
                        </div>
                    </div>
                    <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg bg-blue-50 text-blue-600 mb-3"><i class="fa-solid fa-building"></i></div>
                        <div>
                            <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide m-0 mb-1">Occupancy Rate</p>
                            <p class="text-2xl font-bold text-slate-800 m-0 leading-none"><%= stats.occupancyRate %>%</p>
                        </div>
                    </div>
                    <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg bg-amber-50 text-amber-600 mb-3"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                        <div>
                            <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide m-0 mb-1">Open Tickets</p>
                            <p class="text-2xl font-bold text-slate-800 m-0 leading-none"><%= stats.openMaintenance %></p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!--Income Summary Performance Visual Graph Chart SVG Matrix Workspace Block Layout-->
                    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col p-6">
                        <div class="mb-4">
                            <h3 class="text-base font-bold text-slate-800 m-0 flex items-center gap-2"><i class="fa-solid fa-chart-line text-indigo-600"></i> Revenue Overview</h3>
                            <p class="text-xs text-slate-500 m-0 mt-1">Monthly collection streams snapshot metrics overview data graph</p>
                        </div>
                        <div class="h-48 flex items-end justify-between gap-4 px-2 pb-2 border-b border-slate-100">
                            <% chartData.forEach(function(d) { %>
                                <div class="flex flex-col items-center flex-1 gap-2 group relative">
                                    <div class="w-full bg-indigo-500 rounded-t-md opacity-70 group-hover:opacity-100 transition-opacity" style="height: <%= d.percentage %>%;"></div>
                                    <span class="text-[10px] sm:text-xs font-semibold text-slate-500"><%= d.month %></span>
                                </div>
                            <% }); %>
                        </div>
                    </div>

                    <!--Building Units Allocation Proportions Circle Progress Section Blocks Layer Component Layout-->
                    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 flex flex-col justify-between">
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 m-0 flex items-center gap-2"><i class="fa-solid fa-building text-blue-600"></i> Asset Allocations</h3>
                            <p class="text-xs text-slate-500 m-0 mt-1">Current compound units configuration layout tracking states</p>
                        </div>
                        <div class="space-y-4 my-auto">
                            <div>
                                <div class="flex justify-between text-xs mb-1"><span class="text-slate-600">Occupied Apartments</span><span class="font-bold text-slate-800"><%= stats.occupiedUnits %></span></div>
                                <div class="w-full bg-slate-100 rounded-full h-2 overflow-hidden"><div class="bg-blue-500 h-2 rounded-full" style="width: <%= stats.occupancyRate %>%;"></div></div>
                            </div>
                            <div>
                                <div class="flex justify-between text-xs mb-1"><span class="text-slate-600">Vacant Layout Rooms</span><span class="font-bold text-slate-800"><%= stats.vacantUnits %></span></div>
                                <div class="w-full bg-slate-100 rounded-full h-2 overflow-hidden"><div class="bg-amber-400 h-2 rounded-full" style="width: <%= 100 - stats.occupancyRate %>%;"></div></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>
</div>
<%- include('../partials/footer') %>