<%- include('../partials/header') %>
<div class="flex h-screen bg-slate-50 overflow-hidden">
    <%- include('../partials/adminSidebar') %>
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="h-20 bg-white border-b border-gray-200 flex items-center px-8 shrink-0 relative z-50">
            <h2 class="text-2xl font-bold text-[#1e293b] m-0 tracking-tight">Unit Management</h2>
        </header>

        <main class="flex-1 overflow-y-auto p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                <!-- Apartment Space Inventory Rooms Grid Layout -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% units.forEach(function(unit) { %>
                        <div class="bg-white border rounded-2xl p-5 transition-all hover:shadow-md relative flex flex-col justify-between <%= unit.status === 'vacant' ? 'border-amber-200 bg-amber-50/30' : 'border-slate-200' %>">
                            <div>
                                <div class="flex justify-between items-start">
                                    <div class="text-xl font-bold text-slate-800">Room <%= unit.roomName %></div>
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-semibold <%= unit.status === 'active' ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' %>">
                                        <%= unit.status === 'active' ? '● Occupied' : '○ Vacant' %>
                                    </span>
                                </div>
                                <div class="text-[11px] text-slate-400 mt-0.5">Studio Unit Layout</div>
                                
                                <% if (unit.status === 'active') { %>
                                    <div class="mt-2 text-xs font-bold text-rose-500">
                                        <i class="fa-regular fa-clock"></i> Next Deadline: <%= unit.deadline %>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Consolidated Unit Modification Form -->
                            <form action="/admin/rooms/update-unit" method="POST" class="mt-4 pt-4 border-t border-slate-100 space-y-3 text-left">
                                <input type="hidden" name="roomName" value="<%= unit.roomName %>" />
                                
                                <!-- Edit Base Rent Option available to ALL units -->
                                <div class="space-y-1">
                                    <label class="text-[9px] uppercase font-black tracking-wider text-slate-500 block">Base Monthly Rent (₱)</label>
                                    <input type="number" name="baseRent" value="<%= unit.monthlyRent %>" required min="0" class="w-full px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs font-bold text-indigo-600 bg-slate-50 outline-none focus:ring-1 focus:ring-indigo-500" />
                                </div>

                                <!-- Utility Inputs (Only shows if there is an active tenant paying them) -->
                                <% if (unit.status === 'active') { %>
                                    <label class="text-[9px] uppercase font-black tracking-wider text-slate-500 block mt-2 pt-2 border-t border-slate-100/50">Utility Statements</label>
                                    <div class="grid grid-cols-2 gap-2">
                                        <div class="space-y-1">
                                            <span class="text-[9px] font-bold text-slate-400 block">Electricity</span>
                                            <input type="number" name="electricity" value="<%= unit.electricity %>" placeholder="Electricity (₱)" required min="0" class="w-full px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs text-slate-800 bg-slate-50 outline-none focus:ring-1 focus:ring-indigo-500" />
                                        </div>
                                        <div class="space-y-1">
                                            <span class="text-[9px] font-bold text-slate-400 block">Water</span>
                                            <input type="number" name="water" value="<%= unit.water %>" placeholder="Water (₱)" required min="0" class="w-full px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs text-slate-800 bg-slate-50 outline-none focus:ring-1 focus:ring-indigo-500" />
                                        </div>
                                    </div>
                                <% } %>

                                <button type="submit" class="w-full bg-[#6366f1] hover:bg-[#4f46e5] text-white font-bold py-2 rounded-lg text-[10px] border-0 cursor-pointer transition-colors shadow-sm mt-1">
                                    Save Form Updates
                                </button>
                            </form>

                        </div>
                    <% }); %>
                </div>
            </div>
        </main>
    </div>
</div>
<%- include('../partials/footer') %>