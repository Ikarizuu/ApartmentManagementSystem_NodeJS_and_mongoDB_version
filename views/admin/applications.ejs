<%- include('../partials/header') %>
<div class="flex h-screen bg-slate-50 overflow-hidden">
    <!--Admin Left Rail Layout Sidebar-->
    <%- include('../partials/adminSidebar') %>

    <!--Right Main Interface Window Panel Area Layout Container-->
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0 select-none relative z-50">
            <h2 class="text-2xl font-bold text-[#1e293b] m-0 tracking-tight">Review Rent Applications</h2>
        </header>

        <main class="flex-1 overflow-y-auto p-6 md:p-8">
            <div class="mx-auto max-w-7xl space-y-6">
                
                <% if (applications.length === 0) { %>
                    <!--Empty State Display-->
                    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center shadow-sm">
                        <div class="w-16 h-16 bg-slate-50 text-slate-400 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl border border-slate-100">
                            <i class="fa-solid fa-folder-open"></i>
                        </div>
                        <h3 class="text-slate-700 font-bold m-0 text-base">No Pending Applications</h3>
                        <p class="text-slate-400 text-xs m-0 mt-1 leading-relaxed">You are all caught up! No incoming tenant lease requests need review right now.</p>
                    </div>
                <% } else { %>
                    <!--Active Pending Rent Applications List Grid-->
                    <div class="space-y-6">
                        <% applications.forEach(function(app) { %>
                            <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col lg:flex-row gap-6 justify-between items-stretch transition-all hover:shadow-md">
                                
                                <!--Left Section: Tenant Details Grid-->
                                <div class="flex-grow space-y-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 border border-indigo-100 flex items-center justify-center font-bold text-sm">
                                            <%= app.firstName[0] %><%= app.lastName[0] %>
                                        </div>
                                        <div>
                                            <h3 class="text-base font-bold text-slate-800 m-0">
                                                <%= app.firstName %> <%= app.lastName %> <%= app.suffix || '' %>
                                            </h3>
                                            <p class="text-[11px] text-slate-400 m-0 mt-0.5">Submitted on <%= new Date(app.createdAt).toLocaleDateString() %></p>
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-3 border-t border-slate-100 text-xs">
                                        <div>
                                            <span class="text-slate-400 block mb-1 font-semibold uppercase tracking-wider text-[9px]">Requested Room</span>
                                            <span class="font-bold text-indigo-600"><%= app.roomRequested %></span>
                                        </div>
                                        <div>
                                            <span class="text-slate-400 block mb-1 font-semibold uppercase tracking-wider text-[9px]">Contact Number</span>
                                            <span class="font-bold text-slate-700 font-mono">+63 <%= app.contactNo %></span>
                                        </div>
                                        <div>
                                            <span class="text-slate-400 block mb-1 font-semibold uppercase tracking-wider text-[9px]">Lease Term</span>
                                            <span class="font-bold text-slate-700"><%= app.monthsOfRent %> Months</span>
                                        </div>
                                        <div>
                                            <span class="text-slate-400 block mb-1 font-semibold uppercase tracking-wider text-[9px]">Occupants</span>
                                            <span class="font-bold text-slate-700"><%= app.occupants %> Pax</span>
                                        </div>
                                    </div>

                                    <!--Document Credentials Verification Row-->
                                    <div class="pt-4 border-t border-slate-100 space-y-2">
                                        <span class="text-slate-400 block font-semibold uppercase tracking-wider text-[9px]">Uploaded Credentials Documents</span>
                                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                            
                                            <!--ID Card Front View Thumbnail-->
                                            <div class="bg-slate-50 border border-slate-200/60 p-3 rounded-xl flex flex-col justify-between h-28">
                                                <span class="text-[10px] font-bold text-slate-500 block mb-2">Valid ID (Front)</span>
                                                <button type="button" onclick="openDocPreview('/<%= app.documents.validIdFrontPath %>', 'image')" class="text-indigo-600 bg-transparent border-0 p-0 text-xs text-left font-bold hover:underline cursor-pointer flex items-center gap-1.5 mt-auto">
                                                    <i class="fa-solid fa-magnifying-glass-plus"></i>Inspect Document Image
                                                </button>
                                            </div>

                                            <!--ID Card Back View Thumbnail-->
                                            <div class="bg-slate-50 border border-slate-200/60 p-3 rounded-xl flex flex-col justify-between h-28">
                                                <span class="text-[10px] font-bold text-slate-500 block mb-2">Valid ID (Back)</span>
                                                <button type="button" onclick="openDocPreview('/<%= app.documents.validIdBackPath %>', 'image')" class="text-indigo-600 bg-transparent border-0 p-0 text-xs text-left font-bold hover:underline cursor-pointer flex items-center gap-1.5 mt-auto">
                                                    <i class="fa-solid fa-magnifying-glass-plus"></i>Inspect Document Image
                                                </button>
                                            </div>

                                            <!--NBI Clearance Copy (Dynamic Image or PDF rendering)-->
                                            <div class="bg-slate-50 border border-slate-200/60 p-3 rounded-xl flex flex-col justify-between h-28">
                                                <span class="text-[10px] font-bold text-slate-500 block mb-2">NBI Clearance</span>
                                                <% if (app.documents.nbiClearancePath.toLowerCase().endsWith('.pdf')) { %>
                                                    <button type="button" onclick="openDocPreview('/<%= app.documents.nbiClearancePath %>', 'pdf')" class="text-rose-600 bg-transparent border-0 p-0 text-xs text-left font-bold hover:underline cursor-pointer flex items-center gap-1.5 mt-auto">
                                                        <i class="fa-solid fa-file-pdf"></i>View Clearance PDF File
                                                    </button>
                                                <% } else { %>
                                                    <button type="button" onclick="openDocPreview('/<%= app.documents.nbiClearancePath %>', 'image')" class="text-indigo-600 bg-transparent border-0 p-0 text-xs text-left font-bold hover:underline cursor-pointer flex items-center gap-1.5 mt-auto">
                                                        <i class="fa-solid fa-magnifying-glass-plus"></i>Inspect Document Image
                                                    </button>
                                                <% } %>
                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <!--Right Section: Quick Decision Processing Action Row-->
                                <div class="w-full lg:w-44 border-t lg:border-t-0 lg:border-l border-slate-100 pt-4 lg:pt-0 lg:pl-6 flex flex-row lg:flex-col justify-center items-center gap-3 shrink-0">
                                    <!--Approval Transaction Decision Form-->
                                    <form action="/admin/applications/<%= app._id %>/accept" method="POST" class="w-full">
                                        <button type="submit" class="w-full py-3 px-4 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold border-0 cursor-pointer shadow-sm transition-all flex items-center justify-center gap-1.5">
                                            <i class="fa-solid fa-check"></i>Approve Tenant
                                        </button>
                                    </form>

                                    <!--Rejection Transaction Decision Form-->
                                    <form action="/admin/applications/<%= app._id %>/reject" method="POST" class="w-full">
                                        <button type="submit" class="w-full py-3 px-4 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-xl text-xs font-bold border-0 cursor-pointer transition-all flex items-center justify-center gap-1.5">
                                            <i class="fa-solid fa-xmark"></i>Deny Application
                                        </button>
                                    </form>
                                </div>

                            </div>
                        <% }); %>
                    </div>
                <% } %>

            </div>
        </main>
    </div>
</div>

<!--Interactive Document Viewer Overlay Modal Window-->
<div id="viewer-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all">
    <div class="bg-white w-full max-w-4xl rounded-3xl border border-slate-100 shadow-2xl p-6 md:p-8 text-left relative h-[85vh] flex flex-col">
        <!--Close Modal Button-->
        <button type="button" onclick="closeDocPreview()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 border-0 bg-transparent cursor-pointer text-lg">
            <i class="fa-solid fa-xmark"></i>
        </button>

        <h3 class="text-lg font-bold text-[#3b4276] m-0 border-b border-slate-100 pb-3 mb-4 flex items-center gap-2">
            <i class="fa-solid fa-file-shield text-indigo-500"></i>Document Inspection Viewer
        </h3>

        <!--Dynamic Inspection Canvas Framework Area-->
        <div class="flex-grow w-full bg-slate-100 rounded-2xl overflow-hidden flex items-center justify-center relative min-h-0">
            <!--Image Target Container-->
            <img id="preview-image-canvas" class="hidden max-w-full max-h-full object-contain" src="" alt="Document Copy" />
            <!--PDF Embed Target Container-->
            <embed id="preview-pdf-canvas" class="hidden w-full h-full border-0" src="" type="application/pdf" />
        </div>

        <div class="pt-4 border-t border-slate-100 flex justify-end">
            <button type="button" onclick="closeDocPreview()" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-6 py-2.5 rounded-xl text-xs border-0 cursor-pointer transition-all">
                Close Viewer
            </button>
        </div>
    </div>
</div>

<script>
    //Open document viewer frame overlay dynamically supporting images and PDFs
    function openDocPreview(filePath, fileType) {
        const modal = document.getElementById('viewer-modal');
        const imgCanvas = document.getElementById('preview-image-canvas');
        const pdfCanvas = document.getElementById('preview-pdf-canvas');

        //Reset current canvas state
        imgCanvas.classList.add('hidden');
        pdfCanvas.classList.add('hidden');
        imgCanvas.src = '';
        pdfCanvas.src = '';

        if (fileType === 'pdf') {
            pdfCanvas.src = filePath;
            pdfCanvas.classList.remove('hidden');
        } else {
            imgCanvas.src = filePath;
            imgCanvas.classList.remove('hidden');
        }

        modal.classList.remove('hidden');
    }

    //Close the inspection canvas frame cleanly
    function closeDocPreview() {
        const modal = document.getElementById('viewer-modal');
        modal.classList.add('hidden');
    }

    //Autoclose on outside frame target clicks
    window.addEventListener('click', function(event) {
        const modal = document.getElementById('viewer-modal');
        if (event.target === modal) {
            closeDocPreview();
        }
    });
</script>

<%- include('../partials/footer') %>