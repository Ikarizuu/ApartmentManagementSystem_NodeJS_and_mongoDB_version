<%- include('../partials/header') %>
<div class="flex h-screen bg-slate-50 overflow-hidden">
    <%- include('../partials/adminSidebar') %>
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0 relative z-50">
            <h2 class="text-2xl font-bold text-[#1e293b] m-0 tracking-tight">Announcements System</h2>
        </header>

        <main class="flex-1 overflow-y-auto p-6 md:p-8">
            <div class="max-w-4xl mx-auto space-y-8">
                
                <!-- Top Section: Compose Form -->
                <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
                    <h3 class="text-base font-bold text-slate-800 mb-4 m-0"><i class="fa-solid fa-bullhorn text-indigo-500 mr-2"></i>Broadcast Notice</h3>
                    <form action="/admin/announcements" method="POST" class="space-y-4">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Notice Title</label>
                                <input type="text" name="title" required class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg text-slate-800 outline-none focus:border-indigo-500" placeholder="e.g. Utility Maintenance" />
                            </div>
                            <div>
                                <label class="block text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Target Audience</label>
                                <select name="sendTo" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg text-slate-800 outline-none focus:border-indigo-500 cursor-pointer">
                                    <option value="All">All Registered Users</option>
                                    <option value="Tenants">Active Tenants Only</option>
                                    <option value="Non-Tenants">Non-Tenants Only</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Message Body</label>
                            <textarea name="body" rows="3" required class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg text-slate-800 resize-none outline-none focus:border-indigo-500" placeholder="Type instructions..."></textarea>
                        </div>
                        <button type="submit" class="py-2.5 px-6 bg-indigo-600 text-white rounded-lg text-xs font-semibold hover:bg-indigo-700 shadow-sm border-0 cursor-pointer transition-colors">
                            <i class="fa-solid fa-paper-plane mr-1.5"></i>Send Broadcast
                        </button>
                    </form>
                </div>

                <!-- Bottom Section: History & Filter -->
                <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden flex flex-col">
                    <div class="p-5 border-b border-slate-100 bg-slate-50 flex flex-col sm:flex-row justify-between items-center gap-4">
                        <h3 class="text-sm font-bold text-slate-800 m-0">Live Tenant Feed History</h3>
                        
                        <!-- History Target Filter -->
                        <form action="/admin/announcements" method="GET" class="flex gap-2 items-center">
                            <select name="targetFilter" class="text-xs bg-white border border-slate-200 rounded-lg px-3 py-1.5 outline-none font-semibold text-slate-600 cursor-pointer">
                                <option value="All" <%= (typeof targetFilter !== 'undefined' && targetFilter === 'All') ? 'selected' : '' %>>All Audiences</option>
                                <option value="Tenants" <%= (typeof targetFilter !== 'undefined' && targetFilter === 'Tenants') ? 'selected' : '' %>>Tenants</option>
                                <option value="Non-Tenants" <%= (typeof targetFilter !== 'undefined' && targetFilter === 'Non-Tenants') ? 'selected' : '' %>>Non-Tenants</option>
                            </select>
                            <button type="submit" class="bg-indigo-100 text-indigo-700 font-bold px-3 py-1.5 rounded-lg text-[10px] border border-indigo-200 hover:bg-indigo-200 cursor-pointer">Filter</button>
                        </form>
                    </div>
                    
                    <div class="divide-y divide-slate-100">
                        <% if (announcements.length === 0) { %>
                            <div class="p-10 text-center text-slate-400 text-xs italic">No active announcements broadcasting.</div>
                        <% } else { %>
                            <% announcements.forEach(function(ann) { %>
                                <div class="p-5 hover:bg-slate-50 transition-colors">
                                    <div class="flex justify-between items-start mb-2">
                                        <div class="flex items-center gap-2">
                                            <h4 class="text-sm font-bold text-slate-800 m-0"><%= ann.title %></h4>
                                            <span class="px-2 py-0.5 bg-slate-200 text-slate-600 text-[9px] rounded font-bold uppercase"><%= ann.sendTo %></span>
                                        </div>
                                        <span class="text-[10px] font-mono text-slate-400"><%= new Date(ann.createdAt).toLocaleDateString() %></span>
                                    </div>
                                    <p class="text-xs text-slate-500 leading-relaxed m-0 mb-3"><%= ann.body %></p>
                                    
                                    <div class="flex gap-2">
                                        <!-- Edit Action trigger -->
                                        <button type="button" onclick="openEditModal('<%= ann._id %>', '<%= ann.title.replace(/'/g, "\\'") %>', '<%= ann.body.replace(/\n/g, '\\n').replace(/'/g, "\\'") %>', '<%= ann.sendTo %>')" class="text-[10px] text-indigo-600 font-bold uppercase tracking-wider bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded border border-indigo-100 cursor-pointer transition-colors">
                                            <i class="fa-solid fa-pen mr-1"></i> Edit
                                        </button>

                                        <form action="/admin/announcements/<%= ann._id %>/delete" method="POST" class="m-0">
                                            <button type="submit" class="text-[10px] text-rose-500 hover:text-rose-700 font-bold uppercase tracking-wider bg-rose-50 hover:bg-rose-100 px-3 py-1.5 rounded border border-rose-100 cursor-pointer transition-colors">
                                                <i class="fa-solid fa-trash-can mr-1"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>

            </div>
        </main>
    </div>
</div>

<!-- Edit Announcement Modal -->
<div id="edit-announcement-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all">
    <div class="bg-white w-full max-w-md rounded-3xl border border-slate-100 shadow-2xl p-6 md:p-8 text-left relative">
        <button type="button" onclick="document.getElementById('edit-announcement-modal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 border-0 bg-transparent cursor-pointer text-lg">
            <i class="fa-solid fa-xmark"></i>
        </button>
        <h3 class="text-lg font-bold text-slate-800 m-0 mb-4 border-b border-slate-100 pb-3">Edit Announcement</h3>
        
        <form id="edit-form" method="POST" class="space-y-4">
            <div>
                <label class="block text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Title</label>
                <input type="text" id="edit-title" name="title" required class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg text-slate-800 outline-none focus:border-indigo-500" />
            </div>
            <div>
                <label class="block text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Target Audience</label>
                <select id="edit-sendTo" name="sendTo" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg text-slate-800 outline-none focus:border-indigo-500 cursor-pointer">
                    <option value="All">All Registered Users</option>
                    <option value="Tenants">Active Tenants Only</option>
                    <option value="Non-Tenants">Non-Tenants Only</option>
                </select>
            </div>
            <div>
                <label class="block text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Body</label>
                <textarea id="edit-body" name="body" rows="4" required class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg text-slate-800 resize-none outline-none focus:border-indigo-500"></textarea>
            </div>
            <div class="pt-2 flex justify-end">
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-2 rounded-xl text-xs cursor-pointer border-0 transition-all">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModal(id, title, body, sendTo) {
        document.getElementById('edit-form').action = '/admin/announcements/' + id + '/edit';
        document.getElementById('edit-title').value = title;
        document.getElementById('edit-body').value = body;
        document.getElementById('edit-sendTo').value = sendTo;
        document.getElementById('edit-announcement-modal').classList.remove('hidden');
    }
</script>
<%- include('../partials/footer') %>