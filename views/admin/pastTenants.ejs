<%- include('../partials/header') %>
<div class="flex h-screen bg-slate-50 overflow-hidden">
    <%- include('../partials/adminSidebar') %>
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0 relative z-50">
            <h2 class="text-2xl font-bold text-[#1e293b] m-0 tracking-tight">Past Tenants Archive</h2>
        </header>

        <main class="flex-1 overflow-y-auto p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                <% if (pastTenants.length === 0) { %>
                    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center shadow-sm">
                        <div class="w-16 h-16 bg-slate-50 text-slate-400 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl border border-slate-100">
                            <i class="fa-solid fa-folder-open"></i>
                        </div>
                        <h3 class="text-slate-700 font-bold m-0 text-base">Archive Empty</h3>
                        <p class="text-slate-400 text-xs m-0 mt-1 leading-relaxed">No administrative historical records present. Checkout processes have not been initiated by past residents.</p>
                    </div>
                <% } else { %>
                    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                        <table class="w-full text-sm text-left">
                            <thead class="bg-slate-50 border-b border-slate-200 text-xs font-semibold uppercase tracking-wide text-slate-500">
                                <tr>
                                    <th class="px-6 py-4">Tenant Identity</th>
                                    <th class="px-6 py-4">Historical Contact</th>
                                    <th class="px-6 py-4">Move-out Confirmation Date</th>
                                    <th class="px-6 py-4">Lifetime Revenue Yield</th>
                                    <th class="px-6 py-4 text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% pastTenants.forEach(function(t) { %>
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 font-bold text-slate-700"><%= t.user.firstName %> <%= t.user.lastName %></td>
                                        <td class="px-6 py-4 text-slate-500 font-mono"><%= t.contactNo %></td>
                                        <td class="px-6 py-4 text-slate-500 text-xs"><%= t.archivedDate %></td>
                                        <td class="px-6 py-4 font-black text-indigo-600">₱<%= t.totalPaid.toLocaleString() %></td>
                                        <td class="px-6 py-4 text-center">
                                            <% if (t.userId) { %>
                                                <a href="/admin/tenants/<%= t.userId %>/history" class="bg-indigo-50 hover:bg-indigo-100 text-indigo-600 text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-lg border border-indigo-200 shadow-sm transition-all no-underline inline-block">
                                                    <i class="fa-solid fa-receipt mr-1"></i> View History
                                                </a>
                                            <% } else { %>
                                                <span class="text-xs text-slate-400 italic">User Deleted</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </main>
    </div>
</div>
<%- include('../partials/footer') %>