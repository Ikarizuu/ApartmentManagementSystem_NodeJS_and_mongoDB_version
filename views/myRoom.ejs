<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] relative flex flex-col items-center justify-start overflow-y-auto box-border py-10 px-4 md:px-12">
    <!--Full Bleed Background Asset Layer matching MyRoom JSX style-->
    <div class="absolute inset-0 z-0">
        <img src="/images/Apartment_Pic.png" alt="Apartment Background" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/90 via-slate-900/80 to-slate-950/95 z-10"></div>
    </div>

    <div class="w-full max-w-4xl z-10 space-y-8 flex flex-col justify-start text-left">
        
        <!-- Header Banner Section -->
        <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 shadow-2xl flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="space-y-1">
                <div class="flex flex-wrap gap-2 items-center">
                    <% if (application.status === 'pending') { %>
                        <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-amber-500 text-slate-950 animate-pulse">
                            Pending Review
                        </span>
                    <% } else if (application.status === 'accepted') { %>
                        <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-emerald-500 text-white">
                            Active Tenancy
                        </span>
                    <% } %>
                    <span class="text-xs text-indigo-300 font-bold flex items-center space-x-1">
                        <i class="fa-solid fa-map-marker-alt text-[10px]"></i>
                        <span>Maguyam Silang, Cavite</span>
                    </span>
                </div>

                <h1 class="text-3xl md:text-4xl font-sans font-extrabold m-0 text-white tracking-tight leading-tight">
                    Welcome Back, <%= user.first_name %>
                </h1>

                <h2 class="text-xl font-sans font-bold m-0 text-indigo-200 tracking-tight pt-0.5">
                    Assigned Unit: <%= application.roomRequested %>
                </h2>
            </div>
        </div>

        <% if (application.status === 'pending') { %>
            <!-- PENDING REVIEW APPLICATION VIEW -->
            <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/10 shadow-2xl p-6 md:p-8 space-y-6">
                <div class="border-b border-white/10 pb-4">
                    <h3 class="text-lg font-bold text-white m-0 flex items-center gap-2">
                        <i class="fa-solid fa-hourglass-half text-amber-500 animate-spin"></i> Lease Application Under Process
                    </h3>
                    <p class="text-xs text-slate-400 m-0 mt-1">Your rental application details are locked and undergoing verification by system admin.</p>
                </div>

                <!-- Personal Information Grid -->
                <div class="space-y-4">
                    <h4 class="text-xs font-black text-indigo-300 uppercase tracking-wider">I. Personal Details</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl">
                            <span class="text-slate-400 block mb-1">Full Name</span>
                            <span class="font-bold text-white"><%= application.firstName %> <%= application.lastName %> <%= application.suffix || '' %></span>
                        </div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl">
                            <span class="text-slate-400 block mb-1">Contact Number</span>
                            <span class="font-bold text-white font-mono">+63 <%= application.contactNo %></span>
                        </div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl">
                            <span class="text-slate-400 block mb-1">Gender</span>
                            <span class="font-bold text-white"><%= application.gender %></span>
                        </div>
                    </div>
                </div>

                <!-- Lease Details Grid -->
                <div class="space-y-4">
                    <h4 class="text-xs font-black text-indigo-300 uppercase tracking-wider">II. Intended Lease Scope</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl">
                            <span class="text-slate-400 block mb-1">Assigned Unit</span>
                            <span class="font-bold text-indigo-400"><%= application.roomRequested %></span>
                        </div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl">
                            <span class="text-slate-400 block mb-1">Months of Intended Lease</span>
                            <span class="font-bold text-white"><%= application.monthsOfRent %> Months</span>
                        </div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl">
                            <span class="text-slate-400 block mb-1">Total Occupants Limit</span>
                            <span class="font-bold text-white"><%= application.occupants %> / 4 Pax</span>
                        </div>
                    </div>
                </div>

                <!-- Document Upload Verifications -->
                <div class="space-y-4">
                    <h4 class="text-xs font-black text-indigo-300 uppercase tracking-wider">III. Verification Attachments</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                        <div class="p-3 bg-slate-950/40 border border-white/10 rounded-xl text-center">
                            <span class="text-slate-400 block mb-2 font-bold">Government ID (Front)</span>
                            <i class="fa-solid fa-file-image text-2xl text-slate-400 mb-1"></i>
                            <span class="text-[10px] text-slate-300 block font-semibold truncate">Uploaded</span>
                        </div>
                        <div class="p-3 bg-slate-950/40 border border-white/10 rounded-xl text-center">
                            <span class="text-slate-400 block mb-2 font-bold">Government ID (Back)</span>
                            <i class="fa-solid fa-file-image text-2xl text-slate-400 mb-1"></i>
                            <span class="text-[10px] text-slate-300 block font-semibold truncate">Uploaded</span>
                        </div>
                        <div class="p-3 bg-slate-950/40 border border-white/10 rounded-xl text-center">
                            <span class="text-slate-400 block mb-2 font-bold">NBI Clearance</span>
                            <% if (application.documents.nbiClearancePath.toLowerCase().endsWith('.pdf')) { %>
                                <i class="fa-solid fa-file-pdf text-2xl text-rose-500 mb-1"></i>
                            <% } else { %>
                                <i class="fa-solid fa-file-image text-2xl text-slate-400 mb-1"></i>
                            <% } %>
                            <span class="text-[10px] text-slate-300 block font-semibold truncate">Uploaded</span>
                        </div>
                    </div>
                </div>
            </div>
        <% } else if (application.status === 'accepted') { %>
            <!-- ACTIVE LEASE DASHBOARD -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                <!-- Lease Contract Card -->
                <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/10 shadow-2xl p-6 flex flex-col justify-between space-y-6">
                    <div class="space-y-4">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-xl bg-indigo-500/10 text-indigo-300 flex items-center justify-center shrink-0 border border-indigo-500/20">
                                <i class="fa-solid fa-file-contract text-lg"></i>
                            </div>
                            <h3 class="text-lg font-bold text-white m-0">Lease Contract</h3>
                        </div>
                        <p class="text-slate-300 text-xs leading-relaxed m-0 font-medium">
                            View legal bindings, rules, and document authentications associated with your rented room unit.
                        </p>
                    </div>
                    <a href="/view-contract" class="w-full bg-[#6366f1] hover:bg-[#4f46e5] text-white text-center font-bold py-2.5 rounded-xl text-xs border-0 cursor-pointer transition-all no-underline shadow-md">
                        See Contract
                    </a>
                </div>

                <!-- Number of Occupants Card -->
                <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/10 shadow-2xl p-6 flex flex-col justify-between space-y-6">
                    <div class="space-y-4">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-xl bg-slate-500/10 text-slate-300 flex items-center justify-center shrink-0 border border-white/10">
                                <i class="fa-solid fa-users text-lg"></i>
                            </div>
                            <h3 class="text-lg font-bold text-white m-0">No. Occupants</h3>
                        </div>
                        <div class="flex flex-col space-y-1.5 text-left">
                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Active Room Count</label>
                            <input
                                type="number"
                                min="1"
                                max="4"
                                value="<%= application.occupants %>"
                                readonly
                                class="w-full px-4 py-2 rounded-xl bg-slate-950/40 border border-white/10 text-slate-400 focus:outline-none text-sm box-border font-bold cursor-not-allowed"
                            />
                        </div>
                    </div>
                    <button type="button" disabled class="w-full bg-slate-800 text-slate-500 font-bold py-2.5 rounded-xl text-xs border-0 cursor-not-allowed opacity-50 shadow-md">
                        Update Occupants
                    </button>
                </div>

                <!-- Next Bill Due Card -->
                <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/10 shadow-2xl p-6 flex flex-col justify-between space-y-6">
                    <div class="space-y-4">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-xl bg-amber-500/10 text-amber-400 flex items-center justify-center shrink-0 border border-amber-500/20">
                                <i class="fa-solid fa-hourglass-half text-lg animate-pulse"></i>
                            </div>
                            <h3 class="text-lg font-bold text-white m-0">Lease Deposit Due</h3>
                        </div>
                        <div class="space-y-2.5 pt-1 text-left">
                            <div class="flex justify-between text-xs font-semibold text-slate-400">
                                <span>Security Deposit:</span>
                                <span class="text-slate-200 font-bold">
                                    ₱<%= (application.roomRequested.includes('Room I') || application.roomRequested.includes('Room J') || application.roomRequested.includes('Room K') || application.roomRequested.includes('Room L') || application.roomRequested.includes('Room M') || application.roomRequested.includes('Room N') ? 3500 : 4000).toLocaleString() %>
                                </span>
                            </div>
                            <p class="text-[10px] text-slate-400 m-0 leading-relaxed font-medium">Please settle your initial advance deposit rent balance to verify onboarding check-in.</p>
                        </div>
                    </div>
                    <a href="/pay-bills" class="w-full bg-[#10b981] hover:bg-[#059669] text-center text-white font-bold py-2.5 rounded-xl text-xs border-0 cursor-pointer no-underline transition-all shadow-md">
                        Pay Rent Deposit
                    </a>
                </div>

            </div>
        <% } %>

    </div>
</div>

<%- include('partials/footer') %>