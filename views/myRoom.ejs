<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] relative flex flex-col items-center justify-start overflow-y-auto box-border py-10 px-4 md:px-12">
    <div class="absolute inset-0 z-0">
        <img src="/images/Apartment_Pic.png" alt="Apartment Background" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/90 via-slate-900/80 to-slate-950/95 z-10"></div>
    </div>

    <div class="w-full max-w-5xl z-10 space-y-8 flex flex-col justify-start text-left">
        
        <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 shadow-2xl flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="space-y-1">
                <div class="flex flex-wrap gap-2 items-center">
                    <% if (application.status === 'pending') { %>
                        <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-amber-500 text-slate-950 animate-pulse">Pending Review</span>
                    <% } else if (application.status === 'accepted' && isWaitingConfirmation) { %>
                        <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-indigo-500 text-white animate-pulse">Cash Deposit Pending Confirm</span>
                    <% } else if (application.status === 'accepted' && !isPaid) { %>
                        <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-indigo-500 text-white animate-pulse">Accepted - Payment Required</span>
                    <% } else if (isPaid) { %>
                        <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-indigo-600 text-white font-extrabold">ACTIVE TENANCY</span>
                    <% } %>
                    <span class="text-xs text-indigo-300 font-bold flex items-center space-x-1.5">
                        <i class="fa-solid fa-map-marker-alt text-[10px]"></i>
                        <span>Maguyam Silang, Cavite</span>
                    </span>
                </div>

                <h1 class="text-3xl md:text-4xl font-sans font-extrabold m-0 text-white tracking-tight leading-tight">Welcome Back, <%= user.first_name %></h1>
                <h2 class="text-xl font-sans font-medium m-0 text-slate-300 tracking-tight pt-1">Current Assigned Unit: <span class="text-indigo-200 font-bold"><%= application.roomRequested %></span></h2>
                <p class="text-xs text-slate-400 m-0 mt-1 max-w-xl">Studio Apartment — Manage your ongoing tenancy parameters, dates, and contracts.</p>
            </div>
        </div>

        <% if (application.status === 'pending') { %>
            <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/10 shadow-2xl p-6 md:p-8 space-y-6">
                <div class="border-b border-white/10 pb-4">
                    <h3 class="text-lg font-bold text-white m-0 flex items-center gap-2"><i class="fa-solid fa-hourglass-half text-amber-500 animate-spin"></i> Lease Application Under Process</h3>
                    <p class="text-xs text-slate-400 m-0 mt-1">Your rental application details are locked and undergoing verification by system admin.</p>
                </div>
                <div class="space-y-4">
                    <h4 class="text-xs font-black text-indigo-300 uppercase tracking-wider">I. Personal Details</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl"><span class="text-slate-400 block mb-1">Full Name</span><span class="font-bold text-white"><%= application.firstName %> <%= application.lastName %> <%= application.suffix || '' %></span></div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl"><span class="text-slate-400 block mb-1">Contact Number</span><span class="font-bold text-white font-mono">+63 <%= application.contactNo %></span></div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl"><span class="text-slate-400 block mb-1">Gender</span><span class="font-bold text-white"><%= application.gender %></span></div>
                    </div>
                </div>
                <div class="space-y-4">
                    <h4 class="text-xs font-black text-indigo-300 uppercase tracking-wider">II. Intended Lease Scope</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl"><span class="text-slate-400 block mb-1">Assigned Unit</span><span class="font-bold text-indigo-400"><%= application.roomRequested %></span></div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl"><span class="text-slate-400 block mb-1">Months of Intended Lease</span><span class="font-bold text-white"><%= application.monthsOfRent %> Months</span></div>
                        <div class="p-3.5 bg-slate-950/40 border border-white/10 rounded-xl"><span class="text-slate-400 block mb-1">Total Occupants Limit</span><span class="font-bold text-white"><%= application.occupants %> / 4 Pax</span></div>
                    </div>
                </div>
            </div>
        <% } else if (application.status === 'accepted' && isWaitingConfirmation) { %>
            <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/10 shadow-2xl p-8 text-center space-y-6">
                <div class="w-16 h-16 bg-amber-500/10 border border-amber-500/20 text-amber-400 rounded-2xl flex items-center justify-center mx-auto text-2xl animate-pulse">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                </div>
                <div class="space-y-2">
                    <h3 class="text-2xl font-bold text-white m-0">Cash On Hand Deposited</h3>
                    <p class="text-slate-300 text-sm max-w-md mx-auto m-0 leading-relaxed">
                        Your down payment entry has been submitted via **Cash on Hand**. Your dashboard features will unlock fully once the administrator receives the funds and validates the transaction parameters.
                    </p>
                </div>
                <div class="pt-2">
                    <a href="/pay-bills" class="inline-flex bg-slate-800 hover:bg-slate-700 text-white font-bold px-10 py-3 rounded-xl text-xs transition-all shadow-md no-underline">Review Billing Ledger Statement</a>
                </div>
            </div>
        <% } else if (application.status === 'accepted' && !isPaid) { %>
            <div class="bg-slate-900/40 backdrop-blur-md rounded-3xl p-8 text-center space-y-6">
                <div class="w-16 h-16 bg-indigo-50/10 border border-indigo-500/20 text-indigo-400 rounded-2xl flex items-center justify-center mx-auto text-2xl">
                    <i class="fa-solid fa-wallet"></i>
                </div>
                <div class="space-y-2">
                    <h3 class="text-2xl font-bold text-white m-0">Secure Advance Rent Deposit</h3>
                    <p class="text-slate-300 text-sm max-w-md mx-auto m-0">Your lease has been approved! Settle your first advance rent security deposit below to verify your tenant profile and complete assignment onboarding.</p>
                </div>
                <div class="pt-2">
                    <a href="/pay-bills" class="inline-flex bg-[#10b981] hover:bg-[#059669] text-white font-extrabold px-10 py-3.5 rounded-xl text-sm transition-all shadow-md no-underline">Proceed to Deposit Payment</a>
                </div>
            </div>
        <% } else if (isPaid) { %>
            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 flex flex-col justify-between space-y-6 shadow-2xl">
                        <div class="space-y-3">
                            <div class="flex items-center space-x-3 text-white">
                                <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 flex items-center justify-center shrink-0"><i class="fa-solid fa-file-lines text-lg"></i></div>
                                <h3 class="text-base font-bold m-0 tracking-tight">Lease Contract</h3>
                            </div>
                            <p class="text-slate-400 text-xs leading-relaxed m-0 font-normal">View legal bindings, rules, and document authentications associated with your rented room unit.</p>
                        </div>
                        <a href="/view-contract" class="w-full bg-[#5850ec] hover:bg-[#453cda] text-white text-center font-bold py-3 rounded-xl text-xs border-0 cursor-pointer transition-colors no-underline shadow-sm">See Contract</a>
                    </div>

                    <form action="/update-occupants" method="POST" class="m-0 bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 flex flex-col justify-between space-y-6 shadow-2xl">
                        <div class="space-y-3">
                            <div class="flex items-center space-x-3 text-white">
                                <div class="w-10 h-10 rounded-xl bg-slate-500/10 border border-white/10 text-slate-300 flex items-center justify-center shrink-0"><i class="fa-solid fa-users"></i></div>
                                <h3 class="text-base font-bold m-0 tracking-tight">No. Occupants</h3>
                            </div>
                            <div class="space-y-1.5 text-left">
                                <label class="text-[9px] uppercase font-black tracking-widest text-slate-400 block">Active Room Count</label>
                                <div class="relative w-full">
                                    <input type="number" name="occupants" min="1" max="4" value="<%= application.occupants %>" required class="w-full px-4 py-2.5 rounded-xl bg-slate-950/60 border border-white/10 text-white text-sm font-bold outline-none focus:border-indigo-500 transition-all"/>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-slate-800 text-slate-200 font-bold py-3 rounded-xl text-xs border border-white/10 cursor-pointer hover:bg-slate-700 transition-colors shadow-sm">Update Occupants</button>
                    </form>

                    <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 flex flex-col justify-between space-y-6 shadow-2xl relative">
                        <div class="space-y-4">
                            <div class="flex items-center space-x-3 text-white">
                                <div class="w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-400 flex items-center justify-center shrink-0 relative">
                                    <i class="fa-solid fa-file-invoice-dollar"></i>
                                    <% if (typeof showRedPing !== 'undefined' && showRedPing) { %>
                                        <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full border border-slate-900 animate-pulse"></span>
                                    <% } %>
                                </div>
                                <h3 class="text-base font-bold m-0 tracking-tight">Billing & Progress</h3>
                            </div>

                            <div class="space-y-3 text-xs font-medium text-slate-400">
                                <div class="flex justify-between items-center">
                                    <span>Last Cycle Paid:</span>
                                    <span class="text-slate-200 font-semibold font-mono"><%= currentCycleStart %></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Paid Valid Until:</span>
                                    <span class="text-rose-400 font-bold font-mono"><%= rentDueDateLabel %></span>
                                </div>
                                
                                <div class="pt-3 border-t border-white/10">
                                    <div class="flex justify-between text-[10px] mb-1.5 uppercase font-bold tracking-wider text-slate-500">
                                        <span>Lease Completion Target</span>
                                        <span class="text-indigo-300"><%= totalPaidMonths %> / <%= contractMaxMonths %> Months</span>
                                    </div>
                                    <div class="w-full bg-slate-950 rounded-full h-1.5 overflow-hidden shadow-inner">
                                        <div class="bg-indigo-500 h-1.5 rounded-full transition-all duration-500" style="width: <%= Math.min((totalPaidMonths / contractMaxMonths) * 100, 100) %>%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <a href="/pay-bills" class="w-full bg-[#10b981] hover:bg-[#059669] text-white text-center font-bold py-3 rounded-xl text-xs border-0 cursor-pointer transition-colors no-underline shadow-sm">
                            Pay / View Statement Actions
                        </a>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch">
                    <!-- DOM REMOVAL LOCKOUT: Completely hides the extension controls if tenancy conclusion is requested -->
                    <% if (activeTenant && (activeTenant.status === 'Pending Moveout' || activeTenant.status === 'Final Term Active')) { %>
                        <div class="md:col-span-12 bg-amber-950/20 backdrop-blur-md border border-amber-900/30 rounded-3xl p-8 flex flex-col justify-center items-center space-y-4 shadow-2xl text-center relative overflow-hidden">
                            <div class="space-y-3 relative z-10 max-w-3xl">
                                <div class="flex items-center justify-center space-x-3 text-amber-400 mb-2">
                                    <i class="fa-solid <%= activeTenant.status === 'Final Term Active' ? 'fa-calendar-check' : 'fa-box-open' %> text-3xl"></i>
                                    <h3 class="text-2xl font-bold m-0 tracking-tight"><%= activeTenant.status === 'Final Term Active' ? 'Final Term Authorized' : 'Move-Out Processing' %></h3>
                                </div>
                                <% if (activeTenant.status === 'Final Term Active') { %>
                                    <p class="text-slate-300 text-sm leading-relaxed m-0 font-medium">
                                        Management has officially authorized your tenancy conclusion. This is a constant reminder that your lease strictly ends on your final paid target: <strong class="text-amber-300 text-lg ml-1 border-b border-amber-500/50 pb-0.5"><%= rentDueDateLabel %></strong>. You are no longer permitted to extend your contract. Please clear all items by this date.
                                    </p>
                                <% } else { %>
                                    <p class="text-slate-300 text-sm leading-relaxed m-0 font-medium">
                                        You have formally requested to end your lease. You may safely occupy your unit until your next billing target on <strong class="text-amber-300 text-lg ml-1 border-b border-amber-500/50 pb-0.5"><%= rentDueDateLabel %></strong>. We are currently awaiting administrator verification to finalize your move-out parameters. Contract extensions are now locked.
                                    </p>
                                <% } %>
                            </div>
                        </div>
                    <% } else { %>
                        <form action="/extend-lease" method="POST" class="m-0 md:col-span-8 bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 flex flex-col justify-between gap-4 shadow-2xl text-left">
                            <div class="flex items-center space-x-3 text-white">
                                <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 flex items-center justify-center shrink-0"><i class="fa-solid fa-calendar-plus"></i></div>
                                <h3 class="text-base font-bold m-0 tracking-tight">Extend Lease Term</h3>
                            </div>
                            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                                <div class="space-y-1">
                                    <p class="text-slate-400 text-xs leading-relaxed m-0 max-w-sm">Select your targeted extension month up to 6 months beyond current parameters. Rent terms will automatically adjust.</p>
                                </div>
                                <div class="space-y-1.5 shrink-0 w-full md:w-max">
                                    <label class="text-[9px] uppercase font-black tracking-widest text-slate-400 block">EXPECTED RENT END MONTH</label>
                                    <div class="flex gap-2 items-center">
                                        <select name="extendEndMonth" required class="px-4 py-2.5 rounded-xl bg-slate-950/60 border border-white/10 text-white font-semibold text-xs outline-none focus:border-indigo-500 w-full md:w-52 transition-all cursor-pointer">
                                            <option value="" disabled selected>Select Target Month</option>
                                            <% validExtensions.forEach(function(ext) { %>
                                                <option value="<%= ext.val %>"><%= ext.label %></option>
                                            <% }); %>
                                        </select>
                                        <button type="submit" class="bg-[#5850ec] hover:bg-[#453cda] text-white font-bold px-4 py-2.5 rounded-xl text-xs border-0 cursor-pointer shadow-sm shrink-0 transition-colors select-none">Submit Extension</button>
                                    </div>
                                </div>
                            </div>
                        </form>

                        <form action="/terminate-lease" method="POST" id="terminate-lease-form" class="m-0 md:col-span-4 bg-red-950/20 backdrop-blur-md border border-red-900/30 rounded-3xl p-6 flex flex-col justify-between space-y-4 shadow-2xl text-left">
                            <div class="space-y-2">
                                <div class="flex items-center space-x-2 text-red-400 font-bold"><i class="fa-solid fa-right-from-bracket text-sm"></i><h3 class="text-sm font-bold m-0 tracking-tight">Terminate Tenancy</h3></div>
                                <p class="text-slate-400 text-[11px] leading-normal m-0 font-normal">Notice: Intention to checkout must be submitted <strong class="text-red-300">1 - 2 weeks prior</strong> to your next billing cycle.</p>
                            </div>
                            <button type="button" onclick="openTerminateModal()" class="w-full bg-[#e02424] hover:bg-[#c81e1e] text-white font-bold py-2.5 rounded-xl text-xs border-0 cursor-pointer select-none transition-colors shadow-md">End Rent Term</button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<div id="terminate-modal" class="hidden fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all">
    <div class="bg-slate-900 w-full max-w-md rounded-3xl border border-white/10 shadow-2xl p-6 md:p-8 text-left relative text-white">
        <h3 class="text-xl font-bold text-white m-0 border-b border-white/10 pb-4 mb-4 flex items-center gap-2">
            <i class="fa-solid fa-triangle-exclamation text-rose-500"></i> Confirm Tenancy Termination
        </h3>
        
        <p class="text-sm text-slate-300 mb-6 leading-relaxed">
            Are you absolutely sure you want to end your lease? This action will alert the administration and permanently mark your account for move-out processing. Please type <strong class="text-rose-400 font-mono tracking-wide">confirm</strong> to proceed.
        </p>

        <div class="space-y-4">
            <input type="text" id="confirm-terminate-input" onkeyup="checkTerminateConfirm()" autocomplete="off" class="w-full px-4 py-3 rounded-xl bg-slate-950/50 border border-white/10 text-white text-sm font-bold focus:ring-2 focus:ring-rose-500 outline-none text-center tracking-widest placeholder:text-slate-600 placeholder:font-normal" placeholder="Type 'confirm'" />

            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeTerminateModal()" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white font-bold py-3 rounded-xl text-xs border-0 cursor-pointer transition-all shadow-sm">Cancel</button>
                <button type="submit" form="terminate-lease-form" id="terminate-submit-btn" disabled class="flex-1 bg-rose-600/50 text-white/50 font-bold py-3 rounded-xl text-xs border-0 shadow-sm transition-all cursor-not-allowed">End Tenancy</button>
            </div>
        </div>
    </div>
</div>

<script>
    function openTerminateModal() {
        document.getElementById('confirm-terminate-input').value = '';
        checkTerminateConfirm();
        document.getElementById('terminate-modal').classList.remove('hidden');
    }
    
    function closeTerminateModal() {
        document.getElementById('terminate-modal').classList.add('hidden');
    }

    function checkTerminateConfirm() {
        const inputStr = document.getElementById('confirm-terminate-input').value.trim().toLowerCase();
        const submitBtn = document.getElementById('terminate-submit-btn');

        if (inputStr === 'confirm') {
            submitBtn.disabled = false;
            submitBtn.className = "flex-1 bg-rose-600 hover:bg-rose-700 text-white font-bold py-3 rounded-xl text-xs border-0 shadow-md transition-all cursor-pointer";
        } else {
            submitBtn.disabled = true;
            submitBtn.className = "flex-1 bg-rose-600/50 text-white/50 font-bold py-3 rounded-xl text-xs border-0 shadow-sm transition-all cursor-not-allowed";
        }
    }
</script>

<%- include('partials/footer') %>