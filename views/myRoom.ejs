<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] relative flex flex-col items-center justify-start overflow-y-auto box-border py-10 px-4 md:px-12">
    <div class="w-full max-w-6xl z-10 space-y-8 flex flex-col justify-start text-left">
        
        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-2xl flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="space-y-1">
                <span class="text-[9px] tracking-widest uppercase font-black px-2.5 py-1 rounded select-none bg-[#10b981] text-white">
                    Active Tenancy
                </span>
                <h1 class="text-3xl md:text-4xl font-sans font-extrabold m-0 text-white tracking-tight leading-tight">
                    Current Assigned Unit: <%= application.roomName %>
                </h1>
                <p class="text-slate-300 text-xs sm:text-sm m-0 font-medium pt-1">
                    Manage your ongoing tenancy records parameter rules, dates, and contracts.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!--Contract Panel Block Links-->
            <div class="bg-white rounded-3xl border border-slate-200 p-6 flex flex-col justify-between space-y-6 shadow-sm">
                <div class="space-y-4">
                    <h3 class="text-lg font-bold text-slate-800 m-0"><i class="fa-solid fa-file-contract text-indigo-500 mr-2"></i>Lease Contract</h3>
                    <p class="text-slate-500 text-xs leading-relaxed m-0 font-medium">
                        View legal bindings, rules, and document authentications associated with your rented room unit.
                    </p>
                </div>
                <a href="/view-contract" class="w-full bg-[#6366f1] hover:bg-[#4f46e5] text-white text-center font-bold py-2.5 rounded-xl text-xs border-0 cursor-pointer transition-all shadow-md no-underline">
                    See Contract
                </a>
            </div>

            <!--Occupancy Population Counters Block Field Layout Area-->
            <div class="bg-white rounded-3xl border border-slate-200 p-6 flex flex-col justify-between space-y-6 shadow-sm">
                <div class="space-y-4">
                    <h3 class="text-lg font-bold text-slate-800 m-0"><i class="fa-solid fa-users text-slate-500 mr-2"></i>Room Details</h3>
                    <div class="text-sm space-y-2">
                        <div><span class="text-slate-400">Active Room Members Count:</span> <strong class="text-slate-800"><%= application.occupants %></strong></div>
                        <div><span class="text-slate-400">Lease Commitment Term Lifecycle:</span> <strong class="text-slate-800"><%= application.monthsOfRent %> Months</strong></div>
                        <div><span class="text-slate-400">Base Monthly Cost Statements Balance:</span> <strong class="text-emerald-600">₱<%= application.monthlyRent.toLocaleString() %></strong></div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer') %>