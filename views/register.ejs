<%- include('partials/header') %>

<div class="min-h-screen w-full grid grid-cols-1 md:grid-cols-12 overflow-hidden bg-white text-left">
    <div class="hidden md:flex md:col-span-6 relative flex-col items-center justify-center p-12 text-center text-white select-none overflow-hidden bg-[#3b4276]">
        <div class="relative z-20 flex flex-col items-center justify-center">
            <h1 class="ams-logo text-8xl italic font-bold tracking-wider mb-2 text-white border-0 bg-transparent uppercase">
                AMS
            </h1>
            <div class="w-48 border-t border-white/20 my-2"></div>
            <p class="text-xs font-light uppercase tracking-widest text-white/60 m-0">
                Apartment Management System
            </p>
        </div>
    </div>

    <div class="col-span-1 md:col-span-6 flex flex-col justify-center items-center p-8 bg-white">
        <div class="w-full max-w-sm flex flex-col items-center">
            <div class="w-full space-y-4">
                <h2 class="text-3xl font-extrabold text-center mb-6 border-0 text-[#3b4276]">
                    Register
                </h2>

                <% if (typeof message !== 'undefined' && message) { %>
                    <div class="p-3 rounded-xl bg-red-50 border border-red-200 text-red-600 text-sm font-semibold text-center">
                        <%= message %>
                    </div>
                <% } %>

                <form class="space-y-3" action="/register" method="POST">
                    <div class="grid grid-cols-2 gap-3">
                        <input name="first_name" type="text" placeholder="First Name" required class="w-full px-4 py-2.5 rounded-xl bg-slate-100 border border-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-inner text-base text-slate-800" />
                        <input name="last_name" type="text" placeholder="Last Name" required class="w-full px-4 py-2.5 rounded-xl bg-slate-100 border border-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-inner text-base text-slate-800" />
                    </div>

                    <input name="email_address" type="email" placeholder="Email Address" required class="w-full px-4 py-2.5 rounded-xl bg-slate-100 border border-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-inner text-base text-slate-800" />
                    <input name="password" type="password" placeholder="Password" required class="w-full px-4 py-2.5 rounded-xl bg-slate-100 border border-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-inner text-base text-slate-800" />
                    <input name="conPassword" type="password" placeholder="Confirm Password" required class="w-full px-4 py-2.5 rounded-xl bg-slate-100 border border-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-inner text-base text-slate-800" />

                    <button type="submit" class="w-full bg-[#6366f1] hover:bg-[#4f46e5] text-white font-medium py-3 rounded-xl shadow-md transition-all mt-4 border-0 cursor-pointer">
                        Register
                    </button>
                </form>

                <div class="text-center pt-2">
                    <a href="/login" class="text-xs text-indigo-600 font-semibold hover:underline bg-transparent border-0 p-0 cursor-pointer">
                        Already have an Account?
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>