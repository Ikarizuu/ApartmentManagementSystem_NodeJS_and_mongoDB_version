<%- include('partials/header') %>
<%- include('partials/topbar') %>

<!-- Main Container: Left-aligned content layout matching Login/Registration -->
<div class="w-full min-h-[calc(100vh-64px)] relative flex items-center justify-start overflow-y-auto box-border py-10 px-6 md:px-16 lg:px-24">
    
    <!-- Full-Bleed Background Image Layer -->
    <div class="absolute inset-0 z-0">
        <!-- Change the src path below if you rename or place your file in a different folder -->
        <img src="/images/Apartment_Pic.png" alt="Apartment Background" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-900/70 to-slate-950/40"></div>
    </div>

    <!-- Left-aligned Interactive Card -->
    <div class="w-full max-w-xl bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-8 md:p-10 shadow-2xl z-10 flex flex-col justify-start text-left space-y-6">
        
        <div class="space-y-3">
            <!-- Premium Badge Indicator -->
            <span class="text-[9px] tracking-widest uppercase font-black px-3 py-1 rounded bg-indigo-500 text-white w-max select-none">
                Premium Rental Property
            </span>

            <h1 class="text-4xl md:text-5xl font-sans font-extrabold m-0 text-white tracking-tight leading-none select-none">
                Welcome Back, <%= user.first_name %>
            </h1>

            <span class="text-xs text-indigo-300 font-semibold flex items-center space-x-1.5 pt-0.5 select-none">
                <i class="fa-solid fa-map-marker-alt text-[10px]"></i>
                <span>Maguyam Silang, Cavite</span>
            </span>
        </div>

        <p class="text-slate-300 text-sm m-0 font-medium leading-relaxed">
            Convenient housing situated perfectly for your daily commute. Enjoy restful accommodations, reliable utilities, and accessible support services designed around your schedule.
        </p>

        <!-- Dynamic Counter Row and Interaction Action Route -->
        <div class="pt-4 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2 select-none text-slate-400 font-bold text-xs">
                <span>•</span>
                <!-- Dynamic available count -->
                <span><%= availableRoomsCount %> Available Rooms</span>
            </div>

            <a href="/preview" class="w-full sm:w-auto bg-[#10b981] hover:bg-[#059669] text-white font-bold py-3 px-6 rounded-xl text-xs flex items-center justify-center gap-2 border-0 cursor-pointer no-underline transition-all hover:scale-[1.03] active:scale-[0.97] shadow-md">
                <span>Explore Available Rooms</span>
                <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>

    </div>
</div>

<%- include('partials/footer') %>