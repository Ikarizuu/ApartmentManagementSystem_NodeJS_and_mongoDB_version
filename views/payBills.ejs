<%- include('partials/header') %>
<%- include('partials/topbar') %>

<div class="w-full min-h-[calc(100vh-76px)] bg-slate-50 py-10 px-4 md:px-12 box-border flex flex-col items-center">
    <div class="w-full max-w-4xl space-y-8 flex flex-col justify-start text-left">
        
        <!-- Header Section showing dynamic calendar values -->
        <div class="border-b border-slate-200 pb-4">
            <h1 class="text-4xl font-sans font-extrabold m-0 tracking-tight select-none text-[#3b4276]">
                <% if (!isFullyBoarded) { %>
                    Lease Onboarding: Initial Deposit
                <% } else { %>
                    Current Bill Statement
                <% } %>
            </h1>
            <p class="text-slate-500 text-sm mt-1 m-0">
                <% if (!isFullyBoarded) { %>
                    Settle your advance down payment rent parameters below to complete configuration check-in.
                <% } else { %>
                    Review your unit breakdown ledger utilities and authorize transaction clearings securely.
                <% } %>
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
            
            <!-- Left Grid: Billing Items Ledger -->
            <div class="md:col-span-7 bg-white rounded-3xl border border-slate-100 shadow-md p-6 md:p-8 space-y-6">
                <div class="flex justify-between items-center border-b border-slate-100 pb-3">
                    <h3 class="text-lg font-bold m-0 text-[#3b4276]">Statement Ledger</h3>
                </div>

                <div class="space-y-4 text-sm font-medium text-slate-600">
                    <div class="flex justify-between items-center">
                        <span>Advance Rent Deposit (<%= application.roomRequested %>)</span>
                        <span class="font-bold text-slate-900">₱<%= baseRent.toLocaleString() %></span>
                    </div>

                    <% if (isFullyBoarded) { %>
                        <!-- Dynamic metered utility items are only billed once fully checked in -->
                        <div class="flex justify-between items-center">
                            <span>Water (Metered Utilities)</span>
                            <span class="font-bold text-slate-900">₱112.50</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span>Electricity (Metered Utilities)</span>
                            <span class="font-bold text-slate-900">₱1,200.00</span>
                        </div>
                    <% } else { %>
                        <!-- Warning indicator highlighting deposit-only configuration -->
                        <div class="p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-2.5 items-start text-amber-700 text-xs">
                            <i class="fa-solid fa-circle-info text-amber-400 mt-0.5"></i>
                            <span>Utility billing meters (Electricity, Water) will remain unbilled until physical check-in occurs.</span>
                        </div>
                    <% } %>
                </div>

                <div class="border-t-2 border-slate-900 pt-4 mt-4 flex justify-between items-center">
                    <span class="text-base font-extrabold text-slate-800">Total Amount Due:</span>
                    <span class="text-2xl font-black text-indigo-600">
                        ₱<%= (isFullyBoarded ? (baseRent + 1312.5) : baseRent).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
                    </span>
                </div>
            </div>

            <!-- Right Grid: Payment Channels Selection -->
            <div class="md:col-span-5 bg-white rounded-3xl border border-slate-100 shadow-md p-6 md:p-8 space-y-6">
                <h3 class="text-lg font-bold m-0 border-b border-slate-100 pb-3 text-[#3b4276]">Payment Options</h3>
                
                <form onsubmit="executePayment(event)" class="space-y-5">
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-slate-700 block">Select Payment Method</label>
                        <select id="paymentMethod" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none text-slate-800 font-semibold text-sm focus:ring-2 focus:ring-indigo-500">
                            <option value="gcash">GCash Digital Wallet</option>
                            <option value="bank">Bank Transfer Routing</option>
                            <option value="cash">Over-the-Counter Cash</option>
                        </select>
                    </div>

                    <button type="submit" class="w-full bg-[#22c55e] hover:bg-[#16a34a] text-white font-extrabold py-3.5 rounded-xl text-base transition-all duration-150 shadow-md border-0 cursor-pointer text-center">
                        Authorize Payment
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function executePayment(e) {
        e.preventDefault();
        const method = document.getElementById('paymentMethod').value;
        alert(`Initializing payment authorization via ${method.toUpperCase()} channel. Please await receipt confirmation.`);
    }
</script>

<%- include('partials/footer') %>